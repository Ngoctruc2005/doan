<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourismApp.Views.RestaurantDetailPage"
    Title="Chi tiết quán">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="15">

            <Label x:Name="nameLabel"
                   FontSize="24"
                   FontAttributes="Bold"/>

            <Label x:Name="descriptionLabel"
                   FontSize="16"/>

            <Label Text="⭐ Best Seller"
                   FontAttributes="Bold"
                   FontSize="18"/>

            <Label x:Name="bestSellerLabel"
                   TextColor="Red"
                   FontSize="16"/>

            <Label Text="🍜 Menu"
                   FontAttributes="Bold"
                   FontSize="18"/>

            <CollectionView x:Name="menuList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding}" Margin="5"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>