<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps" x:Class="TourismApp.Views.MapPage">
    <Grid>
        <!-- MAP -->
        <maps:Map x:Name="map" MapType="Street" IsShowingUser="True" />
        <!-- PANEL CHI TIẾT -->
        <Frame x:Name="detailPanel" BackgroundColor="White" CornerRadius="20" Padding="15" HasShadow="True" VerticalOptions="End" Margin="10" IsVisible="False">
            <StackLayout Spacing="10">
                <Label x:Name="nameLabel" FontSize="20" FontAttributes="Bold" TextColor="Black"/>
                <Label x:Name="descLabel" FontSize="14" TextColor="Gray"/>
                <Label x:Name="bestSellerLabel" FontSize="14" TextColor="Orange"/>
                <Button Text="Đóng" Clicked="OnCloseClicked"/>
                <Button Text="❤️ Yêu thích"
        Clicked="OnFavoriteClicked"/>
            </StackLayout>
        </Frame>
    </Grid>
</ContentPage>